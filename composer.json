{
    "name": "brokenice/laravel-pgsql-partition",
    "description": "PostgreSQL Partition extension for Laravel.",
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist",
        "test:unit": "phpunit -c phpunit.xml.dist --testsuite unit",
        "test:integration": "phpunit -c phpunit.xml.dist --testsuite integration"
    },
    "minimum-stability": "dev",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Luca Becchetti",
            "email": "luca.becchetti@brokenice.it"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-json": "*",
        "illuminate/database": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "ext-mbstring": "*",
        "ext-pdo_pgsql": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5.10|^10.0|^11.0",
        "mockery/mockery": "^1.4.4|^1.6",
        "laravel/laravel": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "doctrine/dbal": "^3.5|^4.0",
        "php-coveralls/php-coveralls": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Brokenice\\LaravelPgsqlPartition\\": "src/"
        }
    },
    "autoload-dev": {
        "classmap": [
            "tests/Unit"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Brokenice\\LaravelPgsqlPartition\\PartitionServiceProvider"
            ]
        }
    }
}
